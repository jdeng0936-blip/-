# ========================================
# 掘进工作面规程智能生成平台 — 后端环境变量
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ========================================

# --- 应用配置 ---
APP_NAME="掘进工作面规程智能生成平台"
APP_VERSION="0.1.0"
DEBUG=true
SECRET_KEY="dev-secret-key-for-local-testing-only-32chars!"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- 数据库 (PostgreSQL 16 + pgvector) ---
# Docker 内部：postgres:5432  |  本地宿主机：localhost:5433
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5433/excavation_platform"

# --- Redis Stack ---
REDIS_URL="redis://localhost:6380/0"

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- AI / LLM ---
# 方案A: Gemini（推荐，通过 OpenAI 兼容接口）
OPENAI_API_KEY="你的-Gemini-API-Key"
OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
AI_MODEL="gemini-3.1"
GEMINI_API_KEY="你的-Gemini-API-Key"

# 方案B: OpenAI（取消注释下面，注释上面）
# OPENAI_API_KEY="sk-xxx"
# OPENAI_BASE_URL=""
# AI_MODEL="gpt-4o"

# --- 文件存储 (OSS/S3，生产环境用) ---
# OSS_ENDPOINT="https://oss-cn-beijing.aliyuncs.com"
# OSS_ACCESS_KEY_ID=""
# OSS_ACCESS_KEY_SECRET=""
# OSS_BUCKET_NAME="excavation-platform"

# --- LangFuse 可观测性（可选，不配则静默跳过） ---
# LANGFUSE_PUBLIC_KEY="pk-xxx"
# LANGFUSE_SECRET_KEY="sk-xxx"
# LANGFUSE_HOST="https://cloud.langfuse.com"
