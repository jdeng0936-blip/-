# ========================================
# 掘进工作面规程智能生成平台 — 后端环境变量
# 复制此文件为 .env 并填写实际值
# ========================================

# --- 应用配置 ---
APP_NAME="掘进工作面规程智能生成平台"
APP_VERSION="0.1.0"
DEBUG=true
SECRET_KEY="change-me-to-a-random-secret-key-at-least-32-chars"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- 数据库 (PostgreSQL 16 + pgvector) ---
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/excavation_platform"

# --- Redis Stack ---
REDIS_URL="redis://localhost:6379/0"

# --- 文件存储 (OSS/S3) ---
OSS_ENDPOINT="https://oss-cn-beijing.aliyuncs.com"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET_NAME="excavation-platform"

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]
